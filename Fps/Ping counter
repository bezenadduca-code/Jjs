-- LocalScript: FPS + Ping Monitor
-- Place in StarterPlayerScripts

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "PerfMonitor"
screenGui.ResetOnSpawn = false
screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local fpsLabel = Instance.new("TextLabel")
fpsLabel.Size = UDim2.new(0, 120, 0, 20)
fpsLabel.Position = UDim2.new(0.5, -60, 0, 10)
fpsLabel.BackgroundTransparency = 1
fpsLabel.TextSize = 14
fpsLabel.Font = Enum.Font.SourceSansBold
fpsLabel.Text = "FPS: ..."
fpsLabel.TextColor3 = Color3.fromRGB(0, 200, 0)
fpsLabel.TextXAlignment = Enum.TextXAlignment.Center
fpsLabel.Parent = screenGui

local pingLabel = Instance.new("TextLabel")
pingLabel.Size = UDim2.new(0, 120, 0, 20)
pingLabel.Position = UDim2.new(0.5, -60, 0, 30)
pingLabel.BackgroundTransparency = 1
pingLabel.TextSize = 14
pingLabel.Font = Enum.Font.SourceSansBold
pingLabel.Text = "Ping: ..."
pingLabel.TextColor3 = Color3.fromRGB(0, 200, 0)
pingLabel.TextXAlignment = Enum.TextXAlignment.Center
pingLabel.Parent = screenGui

-- FPS calculation
local lastTime = tick()
local frames = 0

RunService.RenderStepped:Connect(function()
	frames = frames + 1
	local now = tick()
	if now - lastTime >= 1 then
		local fps = math.floor(frames / (now - lastTime) + 0.5)
		frames = 0
		lastTime = now
		fpsLabel.Text = "FPS: " .. tostring(fps)

		if fps >= 30 then
			fpsLabel.TextColor3 = Color3.fromRGB(0, 200, 0)   -- green 30+
		else
			fpsLabel.TextColor3 = Color3.fromRGB(255, 0, 0)   -- red below 30
		end
	end
end)

-- Ping update
local function updatePing()
	local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)
	pingLabel.Text = "Ping: " .. tostring(ping) .. " ms"

	if ping < 100 then
		pingLabel.TextColor3 = Color3.fromRGB(0, 200, 0)
	elseif ping < 200 then
		pingLabel.TextColor3 = Color3.fromRGB(255, 165, 0)
	else
		pingLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
	end
end

while true do
	pcall(updatePing)
	wait(2)
end
